# .env.example
# Configurazione base dell'applicazione
VITE_APP_TITLE="Rintraccio Analytics"

# URL dell'API (se presente un backend separato)
VITE_API_URL="http://localhost:3000/api"

# Porta su cui avviare il server di sviluppo
PORT=3000

# Se in futuro aggiungerai un database reale:
# DB_HOST="localhost"
# DB_USER="postgres"
# DB_PASSWORD="la_tua_password_sicura"
# JWT_SECRET="una_stringa_molto_lunga_e_casuale"
